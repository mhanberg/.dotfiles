#!/usr/bin/env bash

# shellcheck disable=SC2016
gh pr list --json number,title,headRefName,updatedAt,author --template '{{range .}}{{$author := .author.login}}{{if .author.name}}{{$author = printf "%s (%s)" .author.name .author.login}}{{end}}{{printf "%s\t%s\t%s\t%s\t%s\n" (printf "#%v" .number | autocolor "green") $author .title .headRefName (timeago .updatedAt)}}{{end}}' |
  fzf \
    --delimiter "\t" \
    --reverse \
    --footer-label="Help" \
    --footer-label-pos=3 \
    --footer-border \
    --footer=$'[ENTER] Open in GitHub\n[CTRL-E] Checkout PR locally\n[CTRL-D] View PR diff\n[CTRL-V] Preview PR\n[CTRL-Y] Preview checks\n[CTRL-T] Reload with open+closed PRs' \
    --preview="GH_FORCE_TTY=true CLICOLOR_FORCE=1 gh pr view --comments {1}" \
    --bind="enter:become(gh pr view -w {1})" \
    --bind="ctrl-e:become(gh pr checkout {1})" \
    --bind="ctrl-t:reload(gh pr list --state=all --limit=10000)" \
    --bind="ctrl-y:change-preview(GH_FORCE_TTY=true CLICOLOR_FORCE=1 gh pr checks --watch {1})" \
    --bind="ctrl-v:change-preview(GH_FORCE_TTY=true CLICOLOR_FORCE=1 gh pr view --comments {1})" \
    --bind="ctrl-d:change-preview(GH_FORCE_TTY=true CLICOLOR_FORCE=1 gh pr diff {1})"
